# Environment Variables Example
# Copy this file to .env.local and fill in your values

# Firebase Configuration (Public - exposed to client)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# AI Configuration (Server-side only - NOT exposed to client)
# DEVELOPMENT PHASE: Using Gemini as temporary provider
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# FUTURE: OpenAI will be added as a provider option
# OPENAI_API_KEY=your_openai_api_key_here
